{
  "name": "tradrs",
  "version": "1.1.18",
  "description": "TRADRS — Predictions Markets Algo Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "start:win": "electron .",
    "dist": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.tradrs.app",
    "productName": "TRADRS Predictions Markets Algo",
    "copyright": "Elegant Hospitality LLC",
    "publish": {
      "provider": "github",
      "owner": "Andersxnnguyen",
      "repo": "TRADRS-Predictions-Markets-Algo"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "TRADRS-Setup-${version}.exe",
      "extraResources": [
        {
          "from": "C:/Users/danbe/OneDrive/Desktop/kalshi_trader_final/kalshi_trader",
          "to": "app",
          "filter": [
            "TRADRS_Predictions_Markets_Algo.exe",
            "static/**/*",
            "!**/__pycache__/**",
            "!**/*.pyc",
            "!**/*.pem",
            "!**/*.py",
            "!**/.git/**",
            "!**/auth.json",
            "!**/settings.json",
            "!**/polymarket_settings.json",
            "!**/pnl_history.json",
            "!**/.env",
            "!**/*.key",
            "!**/*.p12",
            "!**/*.pfx",
            "!**/.venv/**"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.finance",
      "artifactName": "TRADRS-${version}-mac.dmg",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "extraResources": [
        {
          "from": "./dist_mac/TRADRS_Predictions_Markets_Algo",
          "to": "app",
          "filter": ["**/*"]
        }
      ]
    },
    "dmg": {
      "title": "TRADRS Predictions Markets Algo",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  },
  "author": "Elegant Hospitality LLC",
  "license": "MIT"
}
